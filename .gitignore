```gitignore
# =========================================================
# Dependencies
# =========================================================
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# =========================================================
# Build Output
# =========================================================
.next/
out/
build/
dist/

# =========================================================
# Production / Deployment
# =========================================================
.vercel/
.turbo/

# =========================================================
# Coverage
# =========================================================
coverage/

# =========================================================
# Environment Variables
# =========================================================
.env
.env.*
!.env.example

# =========================================================
# Logs
# =========================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================================================
# TypeScript
# =========================================================
*.tsbuildinfo
next-env.d.ts

# =========================================================
# Cache Files
# =========================================================
.cache/
.parcel-cache/

# =========================================================
# Editor & IDE
# =========================================================
.vscode/
.idea/

# =========================================================
# OS Files
# =========================================================
.DS_Store
Thumbs.db

# =========================================================
# Temporary Files
# =========================================================
*.tmp
*.temp
*.swp
*.swo
*~

# =========================================================
# Security Files
# =========================================================
*.pem
*.key

# =========================================================
# C++ / Competitive Programming
# =========================================================
*.exe
*.out
*.o
*.obj
*.gch

# =========================================================
# Python (optional)
# =========================================================
__pycache__/
*.pyc
venv/

# =========================================================
# Misc
# =========================================================
.history/
```
